# Bot Discord
DISCORD_TOKEN=ton-token-discord
GUILD_ID=id-serveur-dsicord

# OAuth2 Discord
DISCORD_CLIENT_ID=ton-client-id
DISCORD_CLIENT_SECRET=ton-client-secret
DISCORD_REDIRECT_URI=https://ton-domaine.up.railway.app/auth/callback

# Sécurité session
SESSION_SECRET=change-ce-truc-en-quelque-chose-de-vraiment-aleatoire-et-long
# 7 jours par défaut, aligné avec src/shared/config.js
SESSION_MAX_AGE_MS=604800000
JSON_BODY_LIMIT=100kb

# Local seulement. Sur Railway, utilise un volume monté sur /data.
DATA_DIR=./data

# Railway le définit automatiquement. En local, tu peux garder 3000.
PORT=3000

# Permissions Discord (IDs séparés par virgules)
ADMIN_USER_ID=952986899667103804
ADMIN_ROLE_ID=1485279148246175764
FULL_ACCESS_ROLES=1485279148246175764,1486744891848654988,1485279534650494976
LIMITED_CRAFT_ACCESS_ROLES=1495448653945634987,1485270431291277383
MAP_VIEW_ROLES=1485279148246175764,1486744891848654988,1485279534650494976,1485270431291277383
LAB_VISIBLE_USERS=952986899667103804,780164840798552066,769670622380294265
MY_WEAPONS_DELETE_ROLE=1490361524408291459

# Supabase uniquement pour les clips du forum Discord, pas pour les images du site.
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_CLIPS_BUCKET=clips
CLIPS_FORUM_CHANNEL_ID=1500520790678962317
CLIPS_MAX_FILE_SIZE_MB=100
CLIPS_BACKFILL_BATCH_SIZE=50
CLIPS_ALLOWED_CATEGORY_IDS=1485642192746971146
